show_install_menu() {
  local selection
  selection=$(menu "Install" "≤░μΘ  Package\nΎΚρ  Web App\n≤▒γν  AI")
  case "$selection" in
  *Package*) terminal pkg-install ;;
  *Web*) tui install-webapp ;;
  #*TUI*) tui tui-install ;;
  *AI*) show_install_ai_menu ;;
  *Windows*) tui "windows-vm install" ;;
  *) show_main_menu ;;
  esac
}

