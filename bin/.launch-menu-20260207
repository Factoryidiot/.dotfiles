show_share_menu() {
  local selection
  selection=$(menu "Share" "ΎΒ┐  Clipboard\nΌσ╗  File \nΎΕΦ  Folder")
  case "$selection" in
  *Clipboard*) cmd-share clipboard ;;
  *File*) terminal bash -c "cmd-share file" ;;
  *Folder*) terminal bash -c "cmd-share folder" ;;
  *) back_to show_trigger_menu ;;
  esac
}

show_toggle_menu() {
  local selection
  selection=$(menu "Toggle" "≤▒ΕΕ  Screensaver\n≤░ΦΟ  Nightlight\n≤▒τΨ  Idle Lock\n≤░Ξε  Top Bar")
  case "$selection" in
  *Screensaver*) toggle-screensaver ;;
  *Nightlight*) toggle-nightlight ;;
  *Idle*) toggle-idle ;;
  *Bar*) toggle-waybar ;;
  *) show_trigger_menu ;;
  esac
}

show_style_menu() {
  local selection
  selection=$(menu "Style" "≤░╕Ν  Theme\nΌββ  Font\nΎΑ╛  Background\nΎΞβ  Hyprland\n≤▒ΕΕ  Screensaver")
  case "$selection" in
  *Theme*) show_theme_menu ;;
  *Font*) show_font_menu ;;
  *Background*) theme-bg-next ;;
  *Hyprland*) open_in_editor ~/.dotfiles/hypr/looknfeel.conf ;;
  *Screensaver*) open_in_editor ~/.dotfiles/screensaver.txt ;;
  *) show_main_menu ;;
  esac
}

show_theme_menu() {
  launch-menu-applications -m menus:omarchythemes --width 800 --minheight 400
}

show_font_menu() {
  local theme
  theme=$(menu "Font" "$(font-list)" "--width 350" "$(font-current)")

  if [[ "$theme" == "CNCLD" || -z "$theme" ]]; then
    back_to show_style_menu
  else
    font-set "$theme"
  fi
}

show_setup_menu() {
  local options="Όα╕  Audio\nΎΘτ  Wifi\n≤░Γψ  Bluetooth\n≤▒ΡΜ  Power Profile\n≤░Ξ╣  Monitors"
  [ -f ~/.dotfiles/hypr/keybindings.conf ] && options="$options\nΎΕε  Keybindings"
  [ -f ~/.dotfiles/hypr/input.conf ] && options="$options\nΌ╛║  Input"
  options="$options\nΌαΧ  Config"

  local selection
  selection=$(menu "Setup" "$options")
  case "$selection" in
  *Audio*) launch-or-focus-tui wiremix ;;
  *Wifi*) launch-wifi ;;
  *Bluetooth*) launch-bluetooth ;;
  *Power*) show_setup_power_menu ;;
  *Monitors*) open_in_editor ~/.dotfiles/hypr/monitors.conf ;;
  *Keybindings*) open_in_editor ~/.dotfiles/hypr/keybindings.conf ;;
  *Input*) open_in_editor ~/.dotfiles/hypr/input.conf ;;
  # *Defaults*) open_in_editor ~/.dotfiles/uwsm/default ;;
  # *Security*) show_setup_security_menu ;;
  *Config*) show_setup_config_menu ;;
  *) show_main_menu ;;
  esac
}

show_setup_power_menu() {
  local profile
  profile=$(menu "Power Profile" "$(display-powerprofiles)" "" "$(powerprofilesctl get)")

  if [[ "$profile" == "CNCLD" || -z "$profile" ]]; then
    back_to show_setup_menu
  else
    powerprofilesctl set "$profile"
  fi
}

show_setup_config_menu() {
  local selection
  selection=$(menu "Setup" "ΎΞβ  Hyprland\nΎΞβ  Hypridle\nΎΞβ  Hyprlock\nΎΞβ  Hyprsunset\nΎΞζ  Swayosd\n≤░Νπ  Walker\n≤░Ξε  Waybar")
  case "$selection" in
  *Hyprland*) open_in_editor ~/.dotfiles/hypr/hyprland.conf ;;
  *Hypridle*) open_in_editor ~/.dotfiles/hypr/hypridle.conf && restart-hypridle ;;
  *Hyprlock*) open_in_editor ~/.dotfiles/hypr/hyprlock.conf ;;
  *Hyprsunset*) open_in_editor ~/.dotfiles/hypr/hyprsunset.conf && restart-hyprsunset ;;
  *Swayosd*) open_in_editor ~/.dotfiles/swayosd/config.toml && restart-swayosd ;;
  *Walker*) open_in_editor ~/.dotfiles/walker/config.toml && restart-walker ;;
  *Waybar*) open_in_editor ~/.dotfiles/waybar/config.jsonc && restart-waybar ;;
  *) show_main_menu ;;
  esac
}

show_vms_menu() {

  local selection

  selection=$(menu "Virtual Machines" "ΎΒπ  Create New VM...\nΎΔν  Manage Existing VMs")

  

  case "$selection" in

    *"Create New VM"*)

      tui install-vm

      ;;

    *"Manage Existing VMs"*)

      tui manage-vms

      ;;

    *)

      show_main_menu

      ;;

  esac

}

