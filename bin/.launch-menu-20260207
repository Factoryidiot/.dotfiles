show_system_menu() {
  local selection
  selection=$(menu "System" "ΎΑμ  Lock\n≤▒ΕΕ  Screensaver\n≤░εΚ  Restart\n≤░Ρξ  Shutdown")
  case "$selection" in
  *Lock*) lock-screen ;;
  *Screensaver*) launch-screensaver force ;;
  *Restart*) cmd-reboot ;;
  *Shutdown*) cmd-shutdown ;;
  *) back_to show_main_menu ;;
  esac
}

show_create_vm_menu() {
  local os_list
  os_list=$(quickget --list-json | jq -r '.[]."OS"' | sort -u)
  
  local selection
  selection=$(menu "Create VM" "$os_list")
  
  if [ -n "$selection" ]; then
    show_release_menu "$selection"
  else
    show_main_menu
  fi
}

show_release_menu() {
  local os="$1"
  local release_list
  release_list=$(quickget --list-json | jq -r --arg os "$os" '.[] | select(.OS == $os) | .Release' | sort -u)
  
  local selection
  selection=$(menu "Select Release for $os" "$release_list")
  
  if [ -n "$selection" ]; then
    show_edition_menu "$os" "$selection"
  else
    show_create_vm_menu
  fi
}

show_edition_menu() {
  local os="$1"
  local release="$2"
  local edition_list
  edition_list=$(quickget --list-json | jq -r --arg os "$os" --arg release "$release" '.[] | select(.OS == $os and .Release == $release) | .Option' | sort -u)
  
  if [ -z "$edition_list" ]; then
    tui quickget "$os" "$release"
    return
  fi
  
  local selection
  selection=$(menu "Select Edition for $os $release" "$edition_list")
  
  if [ -n "$selection" ]; then
    tui quickget "$os" "$release" "$selection"
  else
    show_release_menu "$os"
  fi
}

show_main_menu() {
  local selection
  selection=$(menu "Go" "≤░Α╗  Apps\n≤░πΣ  Learn\n≤▒Υη  Trigger\nΌψΠ  Style\nΌαΧ  Setup\n≤░ΚΚ  Install\n≤░φΝ  Remove\nΎΕΙ  Virtual Machines\nΌσ┤  About\nΎΑΣ  System")
  
  typeset -l lower_selection
  lower_selection="$selection"

  case "$lower_selection" in
  *apps*) 
    launch-menu-applications -p "LaunchέΑο"
    ;; 
  *learn*) show_learn_menu ;;
  *trigger*) show_trigger_menu ;;
  *share*) show_share_menu ;;
  *style*) show_style_menu ;;
  *theme*) show_theme_menu ;;
  *screenshot*) show_screenshot_menu ;;
  *screenrecord*) show_screenrecord_menu ;;
  *setup*) show_setup_menu ;;
  *power*) show_setup_power_menu ;;
  *install*) show_install_menu ;;
  *remove*) show_remove_menu ;;
  *"virtual machines"*) show_vms_menu ;;
  *about*) display-about ;;
  *system*) show_system_menu ;;
  esac
}

show_main_menu
