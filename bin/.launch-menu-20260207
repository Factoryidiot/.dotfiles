#!/usr/bin/env zsh

# Set to true when going directly to a submenu, so we can exit directly
BACK_TO_EXIT=false

back_to() {
  local parent_menu="$1"

  if [[ "$BACK_TO_EXIT" == "true" ]]; then
    exit 0
  elif [[ -n "$parent_menu" ]]; then
    "$parent_menu"
  else
    show_main_menu
  fi
}

menu() {
  local prompt="$1"
  local options="$2"
  local extra="$3"
  local preselect="$4"

  read -r -A args <<<"$extra"

  if [[ -n "$preselect" ]]; then
    local index
    index=$(echo -e "$options" | grep -nxF "$preselect" | cut -d: -f1)
    if [[ -n "$index" ]]; then
      args+=("-c" "$index")
    fi
  fi

  echo -e "$options" | launch-menu-applications --dmenu --width 295 --minheight 1 --maxheight 630 -p "$promptέΑο" "${args[@]}"
}

terminal() {
  xdg-terminal-exec --app-id=dot.nix.terminal "$@"
}

tui() {
  launch-or-focus-tui "$@"
}

open_in_editor() {
  notify-send "Editing config file" "$1"
  launch-editor "$1"
}

show_learn_menu() {
  local selection
  selection=$(menu "Learn" "ΎΕε  Keybindings\nΎΝΥ  Home-Manager\nΎΞβ  Hyprland\nΌγχ  Neovim\nΎΝΥ  Nixos\n≤▒ΗΔ  Zsh")
  case "$selection" in
  *Keybindings*) launch-or-focus-tui display-keybindings ;;
  *Home-Manager*) launch-webapp "https://home-manager-options.extranix.com/" ;;
  *Hyprland*) launch-webapp "https://wiki.hypr.land/" ;;
  *Neovim*) launch-webapp "https://www.lazyvim.org/keymaps" ;;
  *Nixos*) launch-webapp "https://wiki.nixos.org/wiki/NixOS_Wiki" ;;
  *Zsh*) launch-webapp "https://devhints.io/bash" ;;
  *) show_main_menu ;;
  esac
}

show_trigger_menu() {
  local selection
  selection=$(menu "Trigger" "ΎΑ░  Capture\nΎΦΟ  Share\n≤░ΦΟ  Toggle")
  case "$selection" in
  *Capture*) show_capture_menu ;;
  *Share*) show_share_menu ;;
  *Toggle*) show_toggle_menu ;;
  *) show_main_menu ;;
  esac
}

show_capture_menu() {
  local selection
  selection=$(menu "Capture" "ΎΑ░  Screenshot\n≤░ΔΚ  Color")
  case "$selection" in
  *Screenshot*) show_screenshot_menu ;;
  *Color*) pkill hyprpicker || hyprpicker -a ;;
  *) show_trigger_menu ;;
  esac
}

show_screenshot_menu() {
  local selection
  selection=$(menu "Screenshot" "ΎΑ░  Snap with Editing\nΎΑ░  Straight to Clipboard")
  case "$selection" in
  *Editing*) cmd-screenshot smart ;;
  *Clipboard*) cmd-screenshot smart clipboard ;;
  *) show_capture_menu ;;
  esac
}

