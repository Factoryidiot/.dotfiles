show_remove_menu() {
  local selection
  selection=$(menu "Remove" "ΎΚρ  Web App")
  case "$selection" in
  *Web*) tui uninstall-webapp ;;
  *Windows*) tui "windows-vm remove" ;;
  *) show_main_menu ;;
  esac
}

