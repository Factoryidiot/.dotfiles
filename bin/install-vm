#!/usr/bin/env zsh

# --- Configuration ---
PERSISTENT_HOME="/persistent/home/$USER"
ISO_DIR="$PERSISTENT_HOME/Downloads/ISO"
VM_DIR="$PERSISTENT_HOME/VMs"
BIOS_DIR="$HOME/Downloads/BIOS" 

# --- Check for ISOs ---
if [ ! -d "$ISO_DIR" ] || [ -z "$(ls -A "$ISO_DIR" 2>/dev/null)" ]; then
    gum style --padding "1 2" --border double --border-foreground 212 "No ISOs found in $ISO_DIR."
    exit 1
fi

# --- Select ISO ---
iso_list=$(ls -1 "$ISO_DIR")
selected_iso=$(echo "$iso_list" | gum choose)

if [ -z "$selected_iso" ]; then exit 0; fi

# --- System Probe ---
TOTAL_CORES=$(nproc)
SUGGESTED_CORES=$((TOTAL_CORES / 2))
[ "$SUGGESTED_CORES" -eq 0 ] && SUGGESTED_CORES=1

TOTAL_MEM_MB=$(free -m | awk '/^Mem:/ {print $2}')
SUGGESTED_MEM_MB=$((TOTAL_MEM_MB / 2))

# --- Get VM Details ---
echo "Enter VM Details" | gum format
vm_profile=$(gum choose "Generic Linux" "AthenaOS")
[ -z "$vm_profile" ] && exit 0

vm_name=$(gum input --placeholder "VM Name (e.g., ubuntu-server)")
[ -z "$vm_name" ] && exit 0

VM_PATH="$VM_DIR/$vm_name"

if [ -d "$VM_PATH" ]; then
    gum style --padding "1 2" --border double --border-foreground 196 "Error: '$vm_name' already exists."
    exit 1
fi

vm_mem=$(gum input --placeholder "Memory in MB" --value "$SUGGESTED_MEM_MB")
vm_cpus=$(gum input --placeholder "vCPU Cores" --value "$SUGGESTED_CORES")
vm_disk_size=$(gum input --placeholder "Disk Size in GB (e.g., 30)")

# --- Create VM Structure ---
mkdir -p "$VM_PATH/tpm" || exit 1

VM_CONFIG_FILE="$VM_PATH/vm.conf"
VM_DISK_PATH="$VM_PATH/disk.qcow2"
ISO_PATH="$ISO_DIR/$selected_iso"

# --- Write VM Configuration ---
cat <<EOF > "$VM_CONFIG_FILE"
VM_PROFILE="$vm_profile"
VM_NAME="$vm_name"
VM_MEM="$vm_mem"
VM_CPUS="$vm_cpus"
VM_DISK_SIZE="$vm_disk_size"
SELECTED_ISO="$selected_iso"
ISO_PATH="$ISO_PATH"
VM_DISK_PATH="$VM_DISK_PATH"
EOF

# --- Create Disk Image ---
gum spin --spinner dot --title "Creating ${vm_disk_size}G disk image..." -- \
    qemu-img create -f qcow2 "$VM_DISK_PATH" -o nocow=on "${vm_disk_size}G"

gum style --padding "1 2" --border double --border-foreground 212 "VM '$vm_name' configured successfully."

sleep 3
