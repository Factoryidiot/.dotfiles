#!/usr/bin/env zsh

set -e

if [ "$#" -lt 3 ]; then
  echo -e "\e[32mLet's create a new web app you can start with the app launcher.\n\e[0m"
  APP_NAME=$(gum input --prompt "Name> " --placeholder "My favorite web app")
  APP_URL=$(gum input --prompt "URL> " --placeholder "https://example.com")
  ICON_REF=$(gum input --prompt "Icon URL, path or name> " --placeholder "https://example.com/icon.png, /path/to/icon.png or 'firefox'")
  CUSTOM_EXEC=""
  MIME_TYPES=""
  INTERACTIVE_MODE=true
else
  APP_NAME="$1"
  APP_URL="$2"
  ICON_REF="$3"
  CUSTOM_EXEC="$4" # Optional custom exec command
  MIME_TYPES="$5"  # Optional mime types
  INTERACTIVE_MODE=false
fi

# Ensure valid execution
if [[ -z "$APP_NAME" || -z "$APP_URL" || -z "$ICON_REF" ]]; then
  echo "You must set app name, app URL, and icon!"
  exit 1
fi

# Set persistent icon directory for web apps
ICON_DIR="$HOME/.local/share/web-apps/icons"
if ! mkdir -p "$ICON_DIR"; then
  echo "Error: Failed to create icon directory $ICON_DIR."
  exit 1
fi

# Handle icon reference
if [[ $ICON_REF =~ ^https?:// ]]; then
  # It's a URL, download it
  ICON_PATH="$ICON_DIR/$APP_NAME.png"
  if ! curl -sL -o "$ICON_PATH" "$ICON_REF"; then
    echo "Error: Failed to download icon from $ICON_REF."
    exit 1
  fi
elif [[ "$ICON_REF" == /* ]]; then
  # It's an absolute path, check if it exists and use it
  if [ ! -f "$ICON_REF" ]; then
    echo "Error: Icon file not found at absolute path: $ICON_REF"
    exit 1
  fi
  ICON_PATH="$ICON_REF"
elif [ -f "$ICON_REF" ]; then
  # It's a relative path to an existing file, copy it
  if ! cp "$ICON_REF" "$ICON_DIR/"; then
    echo "Error: Failed to copy icon file from $ICON_REF to $ICON_DIR"
    exit 1
  fi
  ICON_PATH="$ICON_DIR/$(basename "$ICON_REF")"
else
  # Assume it's an icon name (e.g., 'firefox')
  ICON_PATH="$ICON_REF"
fi


# Use custom exec if provided, otherwise default behavior
if [[ -n $CUSTOM_EXEC ]]; then
  EXEC_COMMAND="$CUSTOM_EXEC"
else
  EXEC_COMMAND="launch-webapp $APP_URL"
fi

# Create application .desktop file
DESKTOP_DIR="$HOME/.local/share/applications"
if ! mkdir -p "$DESKTOP_DIR"; then
  echo "Error: Failed to create desktop file directory $DESKTOP_DIR."
  exit 1
fi
DESKTOP_FILE="$DESKTOP_DIR/$APP_NAME.desktop"

cat >"$DESKTOP_FILE" <<EOF
[Desktop Entry]
Version=1.0
Name=$APP_NAME
Comment=$APP_NAME Web App
Exec=$EXEC_COMMAND
Terminal=false
Type=Application
Icon=$ICON_PATH
StartupNotify=true
Categories=WebApp;
EOF

# Add mime types if provided
if [[ -n $MIME_TYPES ]]; then
  echo "MimeType=$MIME_TYPES" >>"$DESKTOP_FILE"
fi

chmod +x "$DESKTOP_FILE"

# Refresh the desktop database to make the new file available
update-desktop-database -q "$DESKTOP_DIR" &> /dev/null || true

if [[ $INTERACTIVE_MODE == true ]]; then
  echo -e "\\nYou can now find '$APP_NAME' using the app launcher (SUPER + SPACE)\\n"
fi
