show_remove_menu() {
  local selection
  selection=$(menu "Remove" "ï‰¨  Web App\nَ°چ²  Windows")
  case "$selection" in
  *Web*) tui webapp-remove ;;
  *Windows*) tui "windows-vm remove" ;;
  *) show_main_menu ;;
  esac
}

