show_share_menu() {
  local selection
  selection=$(menu "Share" "ïپ؟  Clipboard\nî©»  File \nï„”  Folder")
  case "$selection" in
  *Clipboard*) cmd-share clipboard ;;
  *File*) terminal bash -c "cmd-share file" ;;
  *Folder*) terminal bash -c "cmd-share folder" ;;
  *) back_to show_trigger_menu ;;
  esac
}

show_toggle_menu() {
  local selection
  selection=$(menu "Toggle" "َ±„„  Screensaver\nَ°”ژ  Nightlight\nَ±«–  Idle Lock\nَ°چœ  Top Bar")
  case "$selection" in
  *Screensaver*) toggle-screensaver ;;
  *Nightlight*) toggle-nightlight ;;
  *Idle*) toggle-idle ;;
  *Bar*) toggle-waybar ;;
  *) show_trigger_menu ;;
  esac
}

show_style_menu() {
  local selection
  selection=$(menu "Style" "َ°¸Œ  Theme\nî™™  Font\nï€¾  Background\nïچ™  Hyprland\nَ±„„  Screensaver")
  case "$selection" in
  *Theme*) show_theme_menu ;;
  *Font*) show_font_menu ;;
  *Background*) theme-bg-next ;;
  *Hyprland*) open_in_editor ~/.dotfiles/hypr/looknfeel.conf ;;
  *Screensaver*) open_in_editor ~/.dotfiles/screensaver.txt ;;
  *) show_main_menu ;;
  esac
}

show_theme_menu() {
  launch-menu-applications -m menus:omarchythemes --width 800 --minheight 400
}

show_font_menu() {
  local theme
  theme=$(menu "Font" "$(font-list)" "--width 350" "$(font-current)")

  if [[ "$theme" == "CNCLD" || -z "$theme" ]]; then
    back_to show_style_menu
  else
    font-set "$theme"
  fi
}

show_setup_menu() {
  local options="îک¸  Audio\nï‡«  Wifi\nَ°‚¯  Bluetooth\nَ±گ‹  Power Profile\nَ°چ¹  Monitors"
  [ -f ~/.dotfiles/hypr/keybindings.conf ] && options="$options\nï„œ  Keybindings"
  [ -f ~/.dotfiles/hypr/input.conf ] && options="$options\nî¾؛  Input"
  options="$options\nï’‰  Defaults\nî¬‘  Security\nîک•  Config"

  local selection
  selection=$(menu "Setup" "$options")
  case "$selection" in
  *Audio*) launch-or-focus-tui wiremix ;;
  *Wifi*) launch-wifi ;;
  *Bluetooth*) launch-bluetooth ;;
  *Power*) show_setup_power_menu ;;
  *Monitors*) open_in_editor ~/.dotfiles/hypr/monitors.conf ;;
  *Keybindings*) open_in_editor ~/.dotfiles/hypr/keybindings.conf ;;
  *Input*) open_in_editor ~/.dotfiles/hypr/input.conf ;;
  *Defaults*) open_in_editor ~/.dotfiles/uwsm/default ;;
  *Security*) show_setup_security_menu ;;
  *Config*) show_setup_config_menu ;;
  *) show_main_menu ;;
  esac
}

show_setup_power_menu() {
  local profile
  profile=$(menu "Power Profile" "$(powerprofiles-list)" "" "$(powerprofilesctl get)")

  if [[ "$profile" == "CNCLD" || -z "$profile" ]]; then
    back_to show_setup_menu
  else
    powerprofilesctl set "$profile"
  fi
}

show_setup_config_menu() {
  local selection
  selection=$(menu "Setup" "ïچ™  Hyprland\nïچ™  Hypridle\nïچ™  Hyprlock\nïچ™  Hyprsunset\nَ±£´  Plymouth\nïچ‌  Swayosd\nَ°Œ§  Walker\nَ°چœ  Waybar")
  case "$selection" in
  *Hyprland*) open_in_editor ~/.dotfiles/hypr/hyprland.conf ;;
  *Hypridle*) open_in_editor ~/.dotfiles/hypr/hypridle.conf && restart-hypridle ;;
  *Hyprlock*) open_in_editor ~/.dotfiles/hypr/hyprlock.conf ;;
  *Hyprsunset*) open_in_editor ~/.dotfiles/hypr/hyprsunset.conf && restart-hyprsunset ;;
  *Plymouth*) open_in_editor ~/.dotfiles/plymouth/config.toml && restart-plymouth ;;
  *Swayosd*) open_in_editor ~/.dotfiles/swayosd/config.toml && restart-swayosd ;;
  *Walker*) open_in_editor ~/.dotfiles/walker/config.toml && restart-walker ;;
  *Waybar*) open_in_editor ~/.dotfiles/waybar/config.jsonc && restart-waybar ;;
  *) show_main_menu ;;
  esac
}

show_setup_security_menu() {
  local selection
  selection=$(menu "Setup" "َ°ˆ·  Fingerprint\nî¬‘  Fido2")
  case "$selection" in
  *Fingerprint*) tui setup-fingerprint ;;
  *Fido2*) tui setup-fido2 ;;
  *) show_setup_menu ;;
  esac
}

show_install_menu() {
  local selection
  selection=$(menu "Install" "َ°£‡  Package\nï‰¨  Web App\nï’‰  TUI\nَ±ڑ¤  AI\nَ°چ²  Windows")
  case "$selection" in
  *Package*) terminal pkg-install ;;
  *Web*) tui webapp-install ;;
  *TUI*) tui tui-install ;;
  *AI*) show_install_ai_menu ;;
  *Windows*) tui "windows-vm install" ;;
  *) show_main_menu ;;
  esac
}

