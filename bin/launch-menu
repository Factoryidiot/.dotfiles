#!/usr/bin/env zsh

# Set to true when going directly to a submenu, so we can exit directly
BACK_TO_EXIT=false

# 0.06s allows the Wayland surface to unmap before the next one maps.
transition_wait() {
  sleep 0.06
}

back_to() {
  local parent_menu="$1"
  [[ "$BACK_TO_EXIT" == "true" ]] && exit 0
  transition_wait
  ${parent_menu:-show_main_menu}
}

menu() {
  local prompt="$1"
  local options="$2"
  local extra="$3"
  local preselect="$4"
  local args=( ${(z)extra} )

  if [[ -n "$preselect" ]]; then
    local opt_array=( ${(f)options} ) # Split options string by newline into a clean native Zsh array
    local index=${opt_array[(I)*$preselect*]} # Find the exact structural index of our preselect element
    [[ $index -gt 0 ]] && args+=("-c" "$index")
  fi

  if systemctl --user is-active --quiet walker.service; then
    print -l -- "${(f)options}" | walker --dmenu --width 295 -p "${prompt}…" "${args[@]}"
  else
    # Fallback to the wrapper if the service is down
    print -r -- "${(f)options}" | launch-menu-applications --dmenu --width 295 -p "${prompt}…" "${args[@]}"
  fi
}

#+----- Submenus ---------------------------------
show_help_menu() {
  local selection
  selection=$(menu "Learn" "  Keybindings\n  Home-Manager\n  Hyprland\n  Neovim\n  Nixos\n󱆃  Zsh")
  case "$selection" in
    *Keybindings*) launch-or-focus-tui display-keybindings ;;
    *Home-Manager*) launch-webapp "https://home-manager-options.extranix.com/" ;;
    *Hyprland*) launch-webapp "https://wiki.hypr.land/" ;;
    *Neovim*) launch-webapp "https://www.lazyvim.org/keymaps" ;;
    *Nixos*) launch-webapp "https://wiki.nixos.org/wiki/NixOS_Wiki" ;;
    *Zsh*) launch-webapp "https://devhints.io/bash" ;;
    *) back_to show_main_menu ;;
  esac
}

show_actions_menu() {
  local selection
  selection=$(menu "Actions" "  Capture\n  Share\n󰔎  Toggle")
  case "$selection" in
    *Capture*) transition_wait; show_capture_menu ;;
    *Share*) transition_wait; show_share_menu ;;
    *Toggle*) transition_wait; show_toggle_menu ;;
    *) back_to show_main_menu ;;
  esac
}

show_capture_menu() {
  local selection
  selection=$(menu "Capture" "  Screenshot\n󰃉  Color")
  case "$selection" in
    *Screenshot*) transition_wait; show_screenshot_menu ;;
    *Color*) pkill hyprpicker || hyprpicker -a ;;
    *) back_to show_actions_menu ;;
  esac
}

show_screenshot_menu() {
  local selection
  selection=$(menu "Screenshot" "  Snap with Editing\n  Straight to Clipboard")
  case "$selection" in
    *Editing*) cmd-screenshot smart ;;
    *Clipboard*) cmd-screenshot smart clipboard ;;
    *) back_to show_capture_menu ;;
  esac
}

show_share_menu() {
  local selection
  selection=$(menu "Share" "  Clipboard\n  File\n  Folder")
  case "$selection" in
    *Clipboard*) cmd-share clipboard ;;
    *File*) xdg-terminal-exec --app-id=dot.nix.terminal bash -c "cmd-share file" ;;
    *Folder*) xdg-terminal-exec --app-id=dot.nix.terminal bash -c "cmd-share folder" ;;
    *) back_to show_actions_menu ;;
  esac
}

show_toggle_menu() {
  local selection
  selection=$(menu "Toggle" "󱄄  Screensaver\n󰔎  Nightlight\n󱫖  Idle Lock\n󰍜  Top Bar")
  case "$selection" in
    *Screensaver*) toggle-screensaver ;;
    *Nightlight*) toggle-nightlight ;;
    *Idle*) toggle-idle ;;
    *Bar*) toggle-waybar ;;
    *) back_to show_actions_menu ;;
  esac
}

show_setup_menu() {
  local options="  Audio\n  Wifi\n󰂯  Bluetooth\n󱐋  Power Profile\n󰍹  Monitors\n  Keybindings\n  Weather"
  local selection
  selection=$(menu "Setup" "$options")
  case "$selection" in
    *Audio*) launch-or-focus-tui wiremix ;;
    *Wifi*) launch-wifi ;;
    *Bluetooth*) launch-bluetooth ;;
    *Power*) transition_wait; show_power_menu ;;
    *Monitors*) launch-editor ~/.dotfiles/hypr/monitors.conf ;;
    *Keybindings*) launch-editor ~/.dotfiles/hypr/keybindings.conf ;;
    *Weather*) transition_wait; show_weather_menu ;;
    *) back_to show_main_menu ;;
  esac
}

show_power_menu() {
  # 1. Fetch raw status directly into an array split by newlines
  local current_raw=("${(f)$(asusctl profile get)}")

  # 2. Extract line 1 and strip "Active profile: " from it
  local active_line="${current_raw[1]}"
  local active_profile="${active_line##Active profile: }"
  
  # Strip hidden whitespaces/tabs
  active_profile="${active_profile//[[:space:]]/}"

  # 3. Establish base profiles map
  local p_label="󰓅  Performance"
  local b_label="󰾆  Balanced"
  local q_label="󰾜  Quiet"

  # 4. Dynamically append a text label to the active item and set the index target
  local preselect=""
  case "${active_profile:l}" in
    performance)
      p_label="$p_label (Current)"
      preselect="Performance"
      ;;
    balanced)
      b_label="$b_label (Current)"
      preselect="Balanced"
      ;;
    quiet)
      q_label="$q_label (Current)"
      preselect="Quiet"
      ;;
  esac

  # 5. Assemble options block with active markers
  local options="${p_label}\n${b_label}\n${q_label}"

  # 6. Hand off to the menu layer
  local selection
  selection=$(menu "Power Profile" "$options" "" "$preselect")

  # 7. Execute system adjustment based on choice
  case "${selection:l}" in
    *performance*) asusctl profile set Performance ;;
    *balanced*)    asusctl profile set Balanced ;;
    *quiet*)       asusctl profile set Quiet ;;
    *)             back_to show_setup_menu ;;
  esac
}

show_weather_menu() {
  local config_file="$HOME/.dotfiles/weather/locations.json"
  if [[ ! -f "$config_file" ]]; then
    # Create a default config if it's missing
    mkdir -p "$(dirname "$config_file")"
    print '{"default": "Te Aro", "locations": ["Te Aro", "Wellington"]}' > "$config_file"
  fi

  local default_location
  default_location=$(jq -r '.default' "$config_file" 2>/dev/null)
  if [[ -z "$default_location" ]]; then
    default_location="Not Set"
  fi

  local options="󰝚 Set Default\n Add Location\n Remove Location"

  local selection
  selection=$(menu "Weather ($default_location)" "$options")

  case "$selection" in
    *"Set Default"*) transition_wait; show_weather_set_default_menu ;;
    *"Add Location"*) transition_wait; show_weather_add_location_menu ;;
    *"Remove Location"*) transition_wait; show_weather_remove_location_menu ;;
    *) back_to show_setup_menu ;;
  esac
}

show_weather_set_default_menu() {
  local config_file="$HOME/.dotfiles/weather/locations.json"
  local default
  default=$(jq -r '.default' "$config_file" 2>/dev/null)
  
  local locations_list=(${(f)"$(jq -r '.locations[]' "$config_file" 2>/dev/null)"})

  local options=""
  local preselect=""
  for loc in "${locations_list[@]}"; do
    if [[ "$loc" == "$default" ]]; then
      options+="󰄬 $loc (Current)\n"
      preselect="$loc"
    else
      options+="󰝖 $loc\n"
    fi
  done
  options=${options%\\n}

  local selection
  selection=$(menu "Set Default Location" "$options" "" "$preselect")

  if [[ -n "$selection" ]]; then
    local chosen_loc=${selection#* } # remove icon
    chosen_loc=${chosen_loc% (Current)*} # remove suffix
    
    if [[ "$chosen_loc" != "$default" ]]; then
        local tmp_file
        tmp_file=$(mktemp)
        jq --arg new_default "$chosen_loc" '.default = $new_default' "$config_file" > "$tmp_file" && mv "$tmp_file" "$config_file"
        pkill -12 waybar
    fi
  fi
  
  back_to show_weather_menu
}

show_weather_add_location_menu() {
  local new_location
  new_location=$(menu "Add New Location" "")

  if [[ -n "$new_location" ]]; then
    local config_file="$HOME/.dotfiles/weather/locations.json"
    
    # Check if location already exists
    if ! jq -e --arg loc "$new_location" '.locations[] | select(. == $loc)' "$config_file" > /dev/null; then
        local tmp_file
        tmp_file=$(mktemp)
        jq --arg new_loc "$new_location" '.locations += [$new_loc]' "$config_file" > "$tmp_file" && mv "$tmp_file" "$config_file"
    fi
  fi

  back_to show_weather_menu
}

show_weather_remove_location_menu() {
  local config_file="$HOME/.dotfiles/weather/locations.json"
  local default
  default=$(jq -r '.default' "$config_file" 2>/dev/null)
  
  local locations_list=(${(f)"$(jq -r '.locations[]' "$config_file" 2>/dev/null)"})

  local options=""
  for loc in "${locations_list[@]}"; do
    if [[ "$loc" == "$default" ]]; then
      options+="󰄬 $loc (Default)\n"
    else
      options+="󰝖 $loc\n"
    fi
  done
  options=${options%\\n}

  local selection
  selection=$(menu "Remove Location" "$options")

  if [[ -n "$selection" && "$selection" != *"(Default)"* ]]; then
    local to_remove=${selection#* } # remove icon
    
    local tmp_file
    tmp_file=$(mktemp)
    jq --arg to_remove "$to_remove" '.locations |= map(select(. != $to_remove))' "$config_file" > "$tmp_file" && mv "$tmp_file" "$config_file"
  fi

  back_to show_weather_menu
}

show_vms_menu() {
  transition_wait
  alacritty --class dot.nix.manage-vms -e manage-vm
}

show_install_menu() {
  local selection
  selection=$(menu "Install" "󰣇  Package\n  Add Web App")
  case "$selection" in
    *Package*) xdg-terminal-exec pkg-install ;;
    *Web*) xdg-terminal-exec install-webapp ;;
    *) back_to show_main_menu ;;
  esac
}

show_system_menu() {
  local selection
  selection=$(menu "System" "  Lock\n󱄄  Screensaver\n󰜉  Restart\n󰐥  Shutdown")
  case "$selection" in
    *Lock*) lock-screen ;;
    *Screensaver*) launch-screensaver force ;;
    *Restart*) cmd-system reboot ;;
    *Shutdown*) cmd-system shutdown ;;
    *) back_to show_main_menu ;;
  esac
}

# --- Main Entry ---

show_main_menu() {
  local selection
  selection=$(menu "Go" "󰀻  Apps\n󱓞  Actions\n  Setup\n  Virtual Machines\n  Web App\n󰧑  Help\n  System")

  case "${selection:l}" in
    *apps*) transition_wait; launch-menu-applications -p "Launch…" ;;
    *actions*) transition_wait; show_actions_menu ;;
    *setup*) transition_wait; show_setup_menu ;;
    *"web app"*) 
      transition_wait
      alacritty --class dot.nix.install-webapp -e install-webapp 
      ;;
    *"virtual machines"*) transition_wait; show_vms_menu ;;
    *help*) transition_wait; show_help_menu ;;
    *system*) transition_wait; show_system_menu ;;
    *) exit 0 ;;
  esac
}

if [[ -n "$1" ]]; then
  local target_func="show_${1:l}_menu"

  if (( $+functions[$target_func] )); then
    BACK_TO_EXIT=true
    $target_func   # Call the function dynamically!
  else
    echo "Error: Submenu '$1' (tried: $target_func) does not exist." >&2
    exit 1
  fi
else
  show_main_menu
fi
