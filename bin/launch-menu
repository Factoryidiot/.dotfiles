#!/usr/bin/env zsh

# Set to true when going directly to a submenu, so we can exit directly
BACK_TO_EXIT=false

# 0.06s allows the Wayland surface to unmap before the next one maps.
transition_wait() {
  sleep 0.06
}

back_to() {
  local parent_menu="$1"
  [[ "$BACK_TO_EXIT" == "true" ]] && exit 0
  transition_wait
  ${parent_menu:-show_main_menu}
}

menu() {
  local prompt="$1"
  local options="$2"
  local extra="$3"
  local preselect="$4"

  read -r -A args <<<"$extra"

  if [[ -n "$preselect" ]]; then
    local index
    index=$(echo -e "$options" | grep -nxF "$preselect" | cut -d: -f1)
    [[ -n "$index" ]] && args+=("-c" "$index")
  fi

  # Check if walker service is active
  if systemctl --user is-active --quiet walker.service; then
    # Use the walker binary to communicate with the service
    printf "%b" "$options" | walker --dmenu --width 295 -p "$promptвА¶" "${args[@]}"
  else
    # Fallback to the wrapper if the service is down
    printf "%b" "$options" | launch-menu-applications --dmenu --width 295 -p "$promptвА¶" "${args[@]}"
  fi
}

#*----- Submenus ---------------------------------

show_help_menu() {
  local selection
  selection=$(menu "Learn" "пДЬ  Keybindings\nпМУ  Home-Manager\nпНЩ  Hyprland\nоЪЃ  Neovim\nпМУ  Nixos\nу±ЖГ  Zsh")
  case "$selection" in
    *Keybindings*) launch-or-focus-tui display-keybindings ;;
    *Home-Manager*) launch-webapp "https://home-manager-options.extranix.com/" ;;
    *Hyprland*) launch-webapp "https://wiki.hypr.land/" ;;
    *Neovim*) launch-webapp "https://www.lazyvim.org/keymaps" ;;
    *Nixos*) launch-webapp "https://wiki.nixos.org/wiki/NixOS_Wiki" ;;
    *Zsh*) launch-webapp "https://devhints.io/bash" ;;
    *) back_to show_main_menu ;;
  esac
}

show_actions_menu() {
  local selection
  selection=$(menu "Actions" "пА∞  Capture\nпФО  Share\nу∞ФО  Toggle")
  case "$selection" in
    *Capture*) transition_wait; show_capture_menu ;;
    *Share*) transition_wait; show_share_menu ;;
    *Toggle*) transition_wait; show_toggle_menu ;;
    *) back_to show_main_menu ;;
  esac
}

show_capture_menu() {
  local selection
  selection=$(menu "Capture" "пА∞  Screenshot\nу∞ГЙ  Color")
  case "$selection" in
    *Screenshot*) transition_wait; show_screenshot_menu ;;
    *Color*) pkill hyprpicker || hyprpicker -a ;;
    *) back_to show_actions_menu ;;
  esac
}

show_screenshot_menu() {
  local selection
  selection=$(menu "Screenshot" "пА∞  Snap with Editing\nпА∞  Straight to Clipboard")
  case "$selection" in
    *Editing*) cmd-screenshot smart ;;
    *Clipboard*) cmd-screenshot smart clipboard ;;
    *) back_to show_capture_menu ;;
  esac
}

show_share_menu() {
  local selection
  selection=$(menu "Share" "пБњ  Clipboard\nо©ї  File\nпДФ  Folder")
  case "$selection" in
    *Clipboard*) cmd-share clipboard ;;
    *File*) xdg-terminal-exec --app-id=dot.nix.terminal bash -c "cmd-share file" ;;
    *Folder*) xdg-terminal-exec --app-id=dot.nix.terminal bash -c "cmd-share folder" ;;
    *) back_to show_actions_menu ;;
  esac
}

show_toggle_menu() {
  local selection
  selection=$(menu "Toggle" "у±ДД  Screensaver\nу∞ФО  Nightlight\nу±ЂЦ  Idle Lock\nу∞НЬ  Top Bar")
  case "$selection" in
    *Screensaver*) toggle-screensaver ;;
    *Nightlight*) toggle-nightlight ;;
    *Idle*) toggle-idle ;;
    *Bar*) toggle-waybar ;;
    *) back_to show_actions_menu ;;
  esac
}

show_setup_menu() {
  local options="оШЄ  Audio\nпЗЂ  Wifi\nу∞Вѓ  Bluetooth\nу±РЛ  Power Profile\nу∞Нє  Monitors\nпДЬ  Keybindings"
  local selection
  selection=$(menu "Setup" "$options")
  case "$selection" in
    *Audio*) launch-or-focus-tui wiremix ;;
    *Wifi*) launch-wifi ;;
    *Bluetooth*) launch-bluetooth ;;
    *Power*) transition_wait; show_setup_power_menu ;;
    *Monitors*) launch-editor ~/.dotfiles/hypr/monitors.conf ;;
    *Keybindings*) launch-editor ~/.dotfiles/hypr/keybindings.conf ;;
    *) back_to show_main_menu ;;
  esac
}

show_setup_power_menu() {
  local current_raw
  current_raw=$(asusctl profile get | grep "Active profile" | awk -F': ' '{print $2}')

  local preselect=""
  case "${current_raw:l}" in
    *performance*) preselect="пГІ  Performance" ;;
    *balanced*)    preselect="пТЉ  Balanced" ;;
    *quiet*)       preselect="рЯМ± Power Saver" ;;
  esac

  local selection
  selection=$(menu "Power Profile" "пГІ  Performance\nпТЉ  Balanced\nрЯМ± Power Saver" "" "$preselect")

  case "$selection" in
    *Performance*) asusctl profile set performance ;;
    *Balanced*)    asusctl profile set balanced ;;
    *Saver*)       asusctl profile set quiet ;;
    *)             back_to show_setup_menu ;;
  esac
}

show_vms_menu() {
  transition_wait
  alacritty --class dot.nix.manage-vms -e manage-vm
}

show_install_menu() {
  local selection
  selection=$(menu "Install" "у∞£З  Package\nпЙ®  Add Web App")
  case "$selection" in
    *Package*) xdg-terminal-exec pkg-install ;;
    *Web*) xdg-terminal-exec install-webapp ;;
    *) back_to show_main_menu ;;
  esac
}

show_system_menu() {
  local selection
  selection=$(menu "System" "пА£  Lock\nу±ДД  Screensaver\nу∞ЬЙ  Restart\nу∞Р•  Shutdown")
  case "$selection" in
    *Lock*) lock-screen ;;
    *Screensaver*) launch-screensaver force ;;
    *Restart*) cmd-system reboot ;;
    *Shutdown*) cmd-system shutdown ;;
    *) back_to show_main_menu ;;
  esac
}

# --- Main Entry ---

show_main_menu() {
  local selection
  selection=$(menu "Go" "у∞Аї  Apps\nу±УЮ  Actions\nоШХ  Setup\nпДИ  Virtual Machines\nпЙ®  Web App\nу∞ІС  Help\nпАС  System")

  case "${selection:l}" in
    *apps*) transition_wait; launch-menu-applications -p "LaunchвА¶" ;;
    *actions*) transition_wait; show_actions_menu ;;
    *setup*) transition_wait; show_setup_menu ;;
    *"web app"*) 
      transition_wait
      alacritty --class dot.nix.install-webapp -e install-webapp 
      ;;
    *"virtual machines"*) transition_wait; show_vms_menu ;;
    *help*) transition_wait; show_help_menu ;;
    *system*) transition_wait; show_system_menu ;;
    *) exit 0 ;;
  esac
}

show_main_menu
