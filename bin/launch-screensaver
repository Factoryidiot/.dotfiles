#!/usr/bin/env zsh

# Exit early if we don't have the tte show
if ! command -v tte &>/dev/null; then
  exit 1
fi

# Exit early if screensave is already running
pgrep -f dot.nix.screensaver && exit 0

# Allow screensaver to be turned off but also force started
if [[ -f ~/.config/screensaver-off ]] && [[ $1 != "force" ]]; then
  exit 1
fi

# Silently quit Walker on overlay
walker -q

focused=$(hyprctl monitors -j | jq -r '.[] | select(.focused == true).name')
terminal=$(xdg-terminal-exec --print-id)

for m in $(hyprctl monitors -j | jq -r '.[] | .name'); do
  # v0.55 Fix: Use Lua API syntax for monitor focusing
  hyprctl dispatch "hl.dsp.focus({ monitor = '$m' })"

  case $terminal in
  *Alacritty*)
    # v0.55 Fix: Use hl.dsp.exec_cmd and escape interior strings with single quotes
    hyprctl dispatch "hl.dsp.exec_cmd('alacritty --class=dot.nix.screensaver --config-file ~/.config/alacritty/screensaver.toml -e cmd-screensaver')"
    ;;
  *)
    notify-send "✋  Screensaver only runs in Alacritty"
    ;;
  esac
done

# v0.55 Fix: Use Lua API syntax to return to the previously focused monitor
hyprctl dispatch "hl.dsp.focus({ monitor = '$focused' })"
