#!/usr/bin/env zsh

# Get the default browser's .desktop file name
browser_desktop_file=$(xdg-settings get default-web-browser)
browser_executable=${browser_desktop_file%.desktop}

case $browser_desktop_file in
firefox* )
    extra_flags=(--no-remote -P "WebApps" --new-window --class WebApp)
    ;;
brave*|helium* )
    extra_flags=(--app="$1" --new-window --class=WebApp)
    shift
    ;;
*)
    extra_flags=(--app="$1")
    shift
    ;;
esac

exec setsid uwsm-app -- "$browser_executable" "${extra_flags[@]}" "$@"
