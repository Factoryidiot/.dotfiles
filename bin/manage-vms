#!/usr/bin/env zsh

# --- Configuration ---
PERSISTENT_HOME="/persistent/home/$USER"
VM_DIR="$PERSISTENT_HOME/VMs"
SHARED_DIR="$HOME/VM_Shared"
BIOS_DIR="$HOME/Downloads/BIOS"
mkdir -p "$SHARED_DIR"

# --- Helper Functions ---
list_vms() {
    local vms=("$VM_DIR"/*(/N:t))
    printf "%s\n" "${vms[@]}"
}

detect_gpu() {
    [ -e "/dev/dri/renderD128" ] && echo "/dev/dri/renderD128" || echo "/dev/dri/renderD129"
}

# --- Actions ---
delete_vm() {
    local vm_name="$1"
    if gum confirm "Are you SURE you want to delete '$vm_name'? This deletes the virtual disk forever."; then
        rm -rf "$VM_DIR/$vm_name"
        gum style --foreground 196 "VM '$vm_name' has been deleted."
    fi
}

reset_disk() {
    local vm_name="$1"
    source "$VM_DIR/$vm_name/vm.conf"
    local disk_path="${VM_DISK_PATH:-$VM_DIR/$vm_name/disk.qcow2}"
    local disk_size="${VM_DISK_SIZE:-30}"

    if gum confirm "Wipe the disk and start fresh? (Deletes all guest data)"; then
        rm -f "$disk_path"
        qemu-img create -f qcow2 "$disk_path" "${disk_size}G"
        gum style --foreground 212 "Disk for '$vm_name' has been reset to ${disk_size}G."
    fi
}

start_vm() {
    local vm_name="$1"
    local conf_path="$VM_DIR/$vm_name/vm.conf"

    [[ -f "$conf_path" ]] && source "$conf_path" || { echo "Config not found"; return 1 }

    local VARS_PATH="$VM_DIR/$vm_name/OVMF_VARS.fd"
    local VARS_TEMPLATE="$BIOS_DIR/OVMF_VARS_4M.secboot.fd"
    local RENDER_NODE=$(detect_gpu)
    VM_DISK_PATH="${VM_DISK_PATH:-$VM_DIR/$vm_name/disk.qcow2}"

    # Ensure VARS exist
    [[ ! -f "$VARS_PATH" ]] && cp "$VARS_TEMPLATE" "$VARS_PATH"

    # --- Start TPM ---
    local TPM_STATE_DIR="$VM_DIR/$vm_name/tpm"
    local TPM_SOCK_PATH="$TPM_STATE_DIR/swtpm-sock"

    mkdir -p "$TPM_STATE_DIR"

    # 1. Kill any existing swtpm process for THIS VM specifically
    # This prevents the "Connection Refused" caused by ghost sockets
    pkill -f "swtpm.*$vm_name" 2>/dev/null
    rm -f "$TPM_SOCK_PATH"

    # 2. Start swtpm
    # We use --daemon to let swtpm handle its own backgrounding safely
    swtpm socket --tpm2 \
        --tpmstate "dir=$TPM_STATE_DIR" \
        --ctrl "type=unixio,path=$TPM_SOCK_PATH" \
        --terminate --daemon

    # 3. Wait for the socket
    local retry=0
    while [[ ! -S "$TPM_SOCK_PATH" && $retry -lt 30 ]]; do
        sleep 0.1
        ((retry++))
    done

    if [[ ! -S "$TPM_SOCK_PATH" ]]; then
        gum style --foreground 196 "Error: TPM socket failed at $TPM_SOCK_PATH"
        return 1
    fi

    # Build Base Command
    local qemu_cmd=("qemu-system-x86_64"
        -name "$VM_NAME" -m "${VM_MEM}M" -smp "$VM_CPUS"
        -object "memory-backend-memfd,id=mem1,size=${VM_MEM}M,share=on"
        -machine "q35,accel=kvm,memory-backend=mem1"
        -cpu host
        # Removed -serial stdio to prevent background stalls
        -drive "if=pflash,format=raw,readonly=on,file=$BIOS_DIR/OVMF_CODE_4M.fd"
        -drive "if=pflash,format=raw,file=$VARS_PATH"
        -chardev "socket,id=chrtpm,path=$TPM_SOCK_PATH" -tpmdev "emulator,id=tpm0,chardev=chrtpm" -device "tpm-tis,tpmdev=tpm0"
        -device "virtio-vga-gl,max_outputs=1" -display "spice-app,gl=on"
        -spice "gl=on,rendernode=$RENDER_NODE,disable-ticketing=on"
        -device "virtio-serial-pci" -chardev "spicevmc,id=spicechannel0,name=vdagent" -device "virtserialport,chardev=spicechannel0,name=com.redhat.spice.0"
        -audiodev "pa,id=sound" -device "ich9-intel-hda" -device "hda-duplex,audiodev=sound"
        -netdev "user,id=net0" -device "virtio-net-pci,netdev=net0"
        -device "qemu-xhci,id=usb-bus" -device "usb-tablet"
        -virtfs "local,path=$SHARED_DIR,mount_tag=hostshare,security_model=mapped-xattr,id=fsdev0"
        -device "virtio-scsi-pci,id=scsi0"
    )

    # Boot Logic
    if [[ -f "$ISO_PATH" ]] && gum confirm "Attach ISO ($ISO_PATH)?"; then
        qemu_cmd+=(-drive "file=$ISO_PATH,media=cdrom,readonly=on,if=none,id=drive-cd0" -device "scsi-cd,bus=scsi0.0,drive=drive-cd0,bootindex=0")
    fi

    qemu_cmd+=(-drive "file=$VM_DISK_PATH,if=none,format=qcow2,id=drive-hd0" -device "scsi-hd,bus=scsi0.0,drive=drive-hd0,bootindex=1")

    # --- Background Execution ---
    local log_file="$VM_DIR/$vm_name/vm.log"
    
    gum style --foreground 212 "🚀 Launching $VM_NAME in background..."
    
    # Launch with nohup, redirect everything to log, and disown the process
    nohup "${qemu_cmd[@]}" > "$log_file" 2>&1 &!
    
    gum style --italic --foreground 240 "Terminal released. Log: $log_file"
}

# --- Main Logic ---
selected_vm=$(list_vms | gum choose --header "Select a Virtual Machine")

if [[ -n "$selected_vm" ]]; then
    action=$(gum choose "Start" "Reset Disk" "Delete VM" "Exit")

    case "$action" in
        "Start") start_vm "$selected_vm" ;;
        "Reset Disk") reset_disk "$selected_vm" ;;
        "Delete VM") delete_vm "$selected_vm" ;;
        "Exit") exit 0 ;;
    esac
fi
