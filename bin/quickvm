#!/usr/bin/env zsh

# --- Configuration ---
PERSISTENT_HOME="/persistent/home/rhys"
VM_DIR="$PERSISTENT_HOME/VMs"
# ---

# Function to stop a VM
stop_vm() {
  local vm_name="$1"
  if [ -z "$vm_name" ]; then
    echo "Usage: $0 stop <vm_name>"
    exit 1
  fi

  # Find the PID by looking for the qemu process with the correct guest name
  local pid=$(ps -ef | grep "[q]emu-system.*-name $vm_name,process=" | awk '{print $2}')
  if [ -n "$pid" ]; then
    kill "$pid"
    echo "VM '$vm_name' stopped."
  else
    echo "VM '$vm_name' is not running."
  fi
}

# --- Main Logic ---
case "$1" in
  stop)
    stop_vm "$2"
    ;;
  *)
    echo "Usage: $0 [stop]"
    exit 1
    ;;
esac
