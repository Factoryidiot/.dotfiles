#!/usr/bin/env zsh

# --- Configuration ---
PERSISTENT_HOME="/persistent/home/$USER"
VM_DIR="$PERSISTENT_HOME/VMs"
# ---

# --- Check for VMs ---
if [ ! -d "$VM_DIR" ] || [ -z "$(find "$VM_DIR" -maxdepth 2 -name "vm.conf")" ]; then
  gum style --padding "1 2" --border double --border-foreground 212 "No virtual machines found in $VM_DIR. Please create one using 'install-vm'."
  exit 1
fi

# --- Select VM ---
vm_list=$(find "$VM_DIR" -maxdepth 2 -name "vm.conf" -printf "%h\n" | xargs -n 1 basename)
selected_vm_name=$(echo -e "Virtual Machine\n$vm_list" | gum table)

if [ -z "$selected_vm_name" ]; then
    exit 0
fi

VM_PATH="$VM_DIR/$selected_vm_name"
VM_CONFIG_FILE="$VM_PATH/vm.conf"

if [ ! -f "$VM_CONFIG_FILE" ]; then
    gum style --padding "1 2" --border double --border-foreground 196 "Error: VM configuration file not found for '$selected_vm_name'."
    exit 1
fi

gum style --padding "1 2" --border double --border-foreground 212 "Selected VM: $selected_vm_name. Loading configuration..."

# Source the configuration file to load variables
source "$VM_CONFIG_FILE"

# At this point, VM_NAME, VM_MEM, VM_CPUS, VM_DISK_SIZE, SELECTED_ISO, ISO_PATH, VM_DISK_PATH are available.

# --- Create disk image if it doesn't exist ---
if [ ! -f "$VM_DISK_PATH" ]; then
    gum spin --title "Creating virtual disk image for '$VM_NAME'" -- \
    qemu-img create -f qcow2 "$VM_DISK_PATH" "${VM_DISK_SIZE}G"
    if [ $? -ne 0 ]; then
        gum style --padding "1 2" --border double --border-foreground 196 "Failed to create virtual disk image for '$VM_NAME'."
        exit 1
    fi
fi

# --- Launch QEMU (Placeholder for now) ---
gum style --padding "1 2" --border double --border-foreground 212 "Launching QEMU for '$VM_NAME' with ${VM_MEM}MB RAM, ${VM_CPUS} CPUs, ${VM_DISK_SIZE}GB disk, and ISO $SELECTED_ISO."
gum style --padding "1 2" --border double --border-foreground 212 "QEMU command will go here."

echo
read "REPLY?Press Enter to close window..."
