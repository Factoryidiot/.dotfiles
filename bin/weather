#!/usr/bin/env zsh

local config_file="$HOME/.dotfiles/weather/locations.json"
local default_location
local encoded_location
local raw_json

if [[ ! -f "$config_file" ]]; then
  # Safe structural fallback JSON if the config is missing
  print '{"text":"’ŗŚ","tooltip":"Weather location config not found","class":"error"}'
  exit 0
fi

default_location=$(jq -r '.default' "$config_file" 2>/dev/null)
if [[ -z "$default_location" ]]; then
  print '{"text":"’ŗŚ","tooltip":"Default location not set in config","class":"error"}'
  exit 0
fi

# URL encode the location
encoded_location=$(jq -s -R -r @uri <<< "$default_location")

raw_json=$(curl -fsS --max-time 4 "https://wttr.in/${encoded_location}?format=j1" 2>/dev/null)

if [[ -z "$raw_json" ]]; then
  # Safe structural fallback JSON if the network drops or wttr.in errors out
  print '{"text":"ŅīĮ","tooltip":"Weather currently unavailable","class":"error"}'
  exit 0
fi

# Multi-variable mapping out of a single jq extraction loop
local -A w
while IFS=$'\t' read -r key value; do
  w[$key]="$value"
done < <(print -r -- "$raw_json" | jq -r '[
  ["code", .current_condition[0].weatherCode],
  ["temp", .current_condition[0].temp_C],
  ["wind", .current_condition[0].windspeedKmph],
  ["desc", .current_condition[0].weatherDesc[0].value],
  ["place", .nearest_area[0].areaName[0].value],
  ["sunrise", .weather[0].astronomy[0].sunrise],
  ["sunset", .weather[0].astronomy[0].sunset]
] | .[] | @tsv' 2>/dev/null)

parse_time_to_int() {
  local time_str="$1"
  local hour="${time_str%%:*}"
  local min="${time_str:3:2}"
  local ampm="${time_str:6:2}"
  (( hour == 12 )) && hour=0
  [[ "$ampm" == "PM" ]] && (( hour += 12 ))
  print $(( hour * 100 + min ))
}

local now_time=$(date +"%H%M")
local sunrise_time=$(parse_time_to_int "${w[sunrise]}")
local sunset_time=$(parse_time_to_int "${w[sunset]}")

local night=false
if (( now_time < sunrise_time || now_time >= sunset_time )); then
  night=true
fi

local icon
case "${w[code]}" in
  113) [[ "$night" == "true" ]] && icon="Ņī½" || icon="ŅīŹ" ;;
  116) [[ "$night" == "true" ]] && icon="Ņī«" || icon="Ņīé" ;;
  119|122) icon="ŅīĮ" ;;
  143|248|260) icon="Ņīō" ;;
  176|263|353) [[ "$night" == "true" ]] && icon="Ņī│" || icon="Ņīł" ;;
  179|227|230|323|326|368) [[ "$night" == "true" ]] && icon="Ņī¦" || icon="ŅīŖ" ;;
  182|185|281|284|311|314|317|320|350|362|365|374|377) icon="ŅÄŁ" ;;
  200|386|389|392|395) icon="ŅīØ" ;;
  266|293|296|299|302|305|308|356|359) icon="Ņīś" ;;
  329|332|335|338|371) icon="ŅīÜ" ;;
  *) icon="ŅīĮ" ;;
esac

# Format text strings cleanly inside memory
local tooltip_text="${w[place]} ┬Ę ${w[desc]} | Temp: ${w[temp]}┬░C | Wind: ${w[wind]} km/h"

# Output structured JSON output straight into Waybar
jq -nc --arg text "$icon" --arg tooltip "$tooltip_text" '{"text": $text, "tooltip": $tooltip}'
